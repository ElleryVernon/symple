# ═══════════════════════════════════════════════════════════════════
#  KKEBI 상담 봇 — 환경 변수
#  사용법:  cp .env.example .env  후 값을 채우세요.
#  (실제 키는 .env 에만 — .env 는 git 에 올라가지 않습니다)
# ═══════════════════════════════════════════════════════════════════

# ── PostgreSQL (Prisma) ────────────────────────────────────────────
# Supabase / Neon / 로컬 등 어떤 Postgres 든 가능.
# 서버리스 배포 시에는 pooled 연결 URL 권장(Supabase pgBouncer / Neon pooled).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB?schema=public"
# (선택) 마이그레이션용 직결 URL — connection pooler 를 쓰는 경우 필요할 수 있음
# DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DB?schema=public"

# ── OpenRouter (LLM) ───────────────────────────────────────────────
# https://openrouter.ai/keys
OPENROUTER_API_KEY=""
# 사용할 모델 슬러그 (기본: Gemini 3.5 Flash — 확인된 실제 슬러그)
OPENROUTER_MODEL="google/gemini-3.5-flash"
# reasoning 강도: minimal | low | medium | high
OPENROUTER_REASONING_EFFORT="medium"
# 음성 모드 reasoning 강도(첫 토큰 지연 최소화)
OPENROUTER_VOICE_REASONING_EFFORT="low"
# (선택) OpenRouter 랭킹/식별용 헤더
OPENROUTER_APP_URL="https://symple.kr"
OPENROUTER_APP_TITLE="KKEBI Counsel"

# ── supermemory (세션 간 기억) ─────────────────────────────────────
# https://console.supermemory.ai  — 미설정 시 기억 기능만 비활성(앱은 정상 동작)
SUPERMEMORY_API_KEY=""

# ── Cartesia (음성 모드 STT/TTS) ───────────────────────────────────
# https://play.cartesia.ai/keys  — 미설정 시 음성 모드만 비활성
CARTESIA_API_KEY=""
# 보이스 라이브러리에서 한국어 보이스 id 를 골라 넣으세요
CARTESIA_VOICE_ID=""
# (선택) 모델 오버라이드
# CARTESIA_TTS_MODEL="sonic-3"        # TTS 모델
# CARTESIA_STT_MODEL="ink-whisper"    # 한국어 지원 STT 모델
